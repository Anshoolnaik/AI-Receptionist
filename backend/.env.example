# Copy this to .env and fill in your values

# Supabase direct connection (port 5432, NOT the pooler port 6543)
# Settings → Database → Connection string → URI
DATABASE_URL=postgresql://app_user:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Groq API key (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Groq model (llama-3.3-70b-versatile is fast and free)
GROQ_MODEL=llama-3.3-70b-versatile

# Mock OTA server URL (run: python mock_ota/mock_ota_server.py)
OTA_BASE_URL=http://localhost:9000

# Path to the knowledge base folder (relative to where you run uvicorn)
KB_DIR=../kb

# Confidence threshold for intent classification (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.6
